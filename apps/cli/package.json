{
  "name": "kandev",
  "version": "0.68.0",
  "private": false,
  "description": "Launcher for Kandev — manage tasks, orchestrate agents, review changes, and ship value",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdlbs/kandev.git"
  },
  "homepage": "https://github.com/kdlbs/kandev",
  "type": "commonjs",
  "bin": {
    "kandev": "bin/cli.js"
  },
  "main": "bin/native-shim.js",
  "files": [
    "bin/cli.js",
    "bin/native-shim.js"
  ],
  "engines": {
    "npm": ">=7"
  },
  "optionalDependencies": {
    "@kdlbs/runtime-linux-x64": "0.0.0-bootstrap",
    "@kdlbs/runtime-linux-arm64": "0.0.0-bootstrap",
    "@kdlbs/runtime-darwin-x64": "0.0.0-bootstrap",
    "@kdlbs/runtime-darwin-arm64": "0.0.0-bootstrap",
    "@kdlbs/runtime-win32-x64": "0.0.0-bootstrap"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.24.0",
    "tar": "^7.5.11",
    "tree-kill": "^1.2.2",
    "tsx": "^4.15.7",
    "typescript": "^5",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node -c bin/cli.js && node -c bin/native-shim.js",
    "bundle": "pnpm build",
    "start": "node bin/cli.js",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  }
}
